---
// Hero.astro
---

<section class="CS_hero relative min-h-screen grid grid-cols-2 border-b-[3px] border-ink overflow-hidden
                dark:border-paper">

  <!-- Halftone dot background -->
  <div class="CS_halftone absolute inset-0 pointer-events-none z-0"></div>

  <!-- Panel divider diagonal -->
  <div class="CS_panel-divider absolute top-0 bottom-0 left-1/2 w-[6px] bg-ink z-10
              dark:bg-paper"></div>

  <!-- Panel numbers -->
  <span class="CS_panel-num absolute top-[88px] left-[80px] font-bangers text-[13px] tracking-[2px]
               text-ink opacity-35 z-10 dark:text-paper">
    01 / HERO
  </span>
  <span class="CS_panel-num absolute top-[88px] right-[60px] font-bangers text-[13px] tracking-[2px]
               text-ink opacity-35 z-10 dark:text-paper">
    EST. 2026
  </span>

  <!-- ───── LEFT PANEL ───── -->
  <div class="relative z-[1] flex flex-col justify-center
              pt-[100px] pb-[60px] pl-[80px] pr-[60px]
              bg-paper dark:bg-ink">

    <!-- Speed lines (decorative, behind text) -->
    <div class="CS_speed-lines absolute top-1/2 -right-10 -translate-y-1/2
                w-[280px] h-[280px] opacity-[0.06] rounded-full pointer-events-none z-0">
    </div>

    <!-- Eyebrow tag -->
    <span class="CS_fade-up [animation-delay:0.1s]
                 inline-flex items-center gap-2 w-fit mb-5
                 bg-comic-red text-white border-[2.5px] border-ink
                 font-bangers text-[15px] tracking-[3px] px-[14px] py-1
                 shadow-[3px_3px_0_#1a1a2e] dark:shadow-[3px_3px_0_#fffbf0]
                 relative z-[2]" data-i18n="hero.eyebrow">
      Portfolio
    </span>

    <!-- Main title -->
    <h1 class="CS_fade-up [animation-delay:0.25s]
               font-bangers leading-[0.92] tracking-wide relative z-[2]
               text-[clamp(64px,8vw,108px)] text-ink dark:text-paper">
      <span data-i18n="hero.titulo">Hola, soy</span>
      <!-- Highlighted word -->
      <span class="CS_highlight relative inline-block">Iván Azuara</span><br>
      <!-- Outline text -->
      <span class="CS_text-outline" data-i18n="hero.rol"></span>
    </h1>

    <!-- Subtitle -->
    <p class="CS_fade-up [animation-delay:0.4s]
              font-quattrocento text-base text-ink leading-relaxed
              mt-6 max-w-[460px] pl-[14px] border-l-4 border-ink
              relative z-[2] dark:text-paper dark:border-paper" data-i18n="hero.subtitulo">
      Descripcion
    </p>

    <!-- CTA buttons -->
    <div class="CS_fade-up [animation-delay:0.55s]
                flex gap-4 mt-9 flex-wrap relative z-[2]">

      <!-- Para Clientes -->
      <a href="#contacto"
         class="font-bangers text-xl tracking-[2px] text-ink bg-yellow
                border-[3px] border-ink px-7 py-[10px]
                shadow-[5px_5px_0_#1a1a2e] dark:shadow-[5px_5px_0_#fffbf0]
                transition-all duration-[120ms]
                hover:-translate-x-0.5 hover:-translate-y-0.5
                hover:shadow-[7px_7px_0_#1a1a2e] dark:hover:shadow-[7px_7px_0_#fffbf0]
                active:translate-x-[3px] active:translate-y-[3px]
                active:shadow-[2px_2px_0_#1a1a2e]" data-i18n="hero.cta_clientes">
        Hablemos de tu proyecto
      </a>

      <!-- Para Reclutadores - CV -->
      <a href={`${import.meta.env.BASE_URL}/CV-IvanAzuara.pdf`} download
         class="font-bangers text-xl tracking-[2px] text-white bg-comic-blue
                border-[3px] border-ink px-7 py-[10px]
                shadow-[5px_5px_0_#1a1a2e] dark:shadow-[5px_5px_0_#fffbf0]
                transition-all duration-[120ms]
                hover:-translate-x-0.5 hover:-translate-y-0.5
                hover:shadow-[7px_7px_0_#1a1a2e] dark:hover:shadow-[7px_7px_0_#fffbf0]
                active:translate-x-[3px] active:translate-y-[3px]
                active:shadow-[2px_2px_0_#1a1a2e]
                flex items-center gap-2" data-i18n="hero.cta_cv">
        <ion-icon name="document-text-outline" class="text-[18px]"></ion-icon>
        Descargar CV
      </a>

      <!-- Para Reclutadores - LinkedIn -->
      <a href="https://www.linkedin.com/in/mario-iván-azuara-del-angel-27b149206/" target="_blank"
         class="font-bangers text-xl tracking-[2px] text-paper bg-ink
                border-[3px] border-ink px-7 py-[10px]
                shadow-[5px_5px_0_#457b9d]
                transition-all duration-[120ms]
                hover:-translate-x-0.5 hover:-translate-y-0.5
                hover:shadow-[7px_7px_0_#457b9d]
                active:translate-x-[3px] active:translate-y-[3px]
                active:shadow-[2px_2px_0_#457b9d]
                dark:bg-paper dark:text-ink flex items-center gap-2" data-i18n="hero.cta_linkedin">
        <ion-icon name="logo-linkedin" class="text-[18px]"></ion-icon>
        LinkedIn
      </a>

    </div>
  </div>

  <!-- ───── RIGHT PANEL ───── -->
  <div class="relative z-[1] flex items-center justify-center
              pt-[100px] pb-[60px] pl-[80px] pr-[60px]
              bg-yellow overflow-hidden dark:bg-[#2a2a4a]">

    <!-- Large bg text -->
    <span class="absolute font-bangers text-[280px] text-ink opacity-[0.05]
                 tracking-[-10px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
                 pointer-events-none whitespace-nowrap select-none">
      DEV
    </span>

    <!-- Avatar wrapper -->
    <div class="CS_avatar-enter relative z-[2]">

      <!-- Speech bubble -->
      <div class="CS_speech-bubble absolute -top-8 -right-14 z-10
                  bg-white border-[3px] border-ink
                  font-bangers text-lg tracking-wide text-ink
                  px-4 py-[10px] -rotate-[4deg] whitespace-nowrap
                  shadow-[4px_4px_0_#1a1a2e]" data-i18n="hero.speech">
        ¡Bienvenido!
      </div>

      <!-- Avatar frame -->
      <div class="CS_avatar-frame relative w-[300px] h-[360px]
                  border-4 border-ink bg-paper
                  shadow-[10px_10px_0_#1a1a2e] rotate-[2deg] overflow-hidden">

        <!-- Action lines -->
        <div class="CS_action-lines absolute inset-[-20px] pointer-events-none"></div>

        <div class="CS_avatar-placeholder w-full h-full relative overflow-hidden">
          <!-- Retro Gameboy Console SVG -->
          <svg viewBox="0 0 200 240" class="w-full h-full p-6 select-none relative z-10" xmlns="http://www.w3.org/2000/svg">
            <!-- Console Body Shadow (Comic brutalist style) -->
            <rect x="29" y="24" width="146" height="196" rx="12" ry="12" fill="#1a1a2e" />

            <!-- Console Body -->
            <rect x="25" y="20" width="146" height="196" rx="12" ry="12" fill="#e2e8f0" stroke="#1a1a2e" stroke-width="5" class="console-body transition-colors duration-300" />
            
            <!-- Screen background / bezel -->
            <rect x="38" y="32" width="120" height="88" rx="6" ry="6" fill="#7a8a99" stroke="#1a1a2e" stroke-width="5" />
            
            <!-- Screen (Default: Green retro) -->
            <g class="screen-default">
              <rect x="46" y="40" width="104" height="72" fill="#8bac0f" stroke="#1a1a2e" stroke-width="4" />
              <!-- Pixel Art grid pattern -->
              <path d="M46 40h104v72H46z" fill="url(#pixel-grid)" opacity="0.15" />
              
              <!-- Retro character / invader -->
              <path d="M92 50h16v6h-16zm-6 6h28v6H86zm-6 6h40v6H80zm-6 6h52v6H74zm12 6h8v6h-8zm20 0h8v6h-8z" fill="#0f380f" />
              
              <text x="98" y="102" font-family="'Bangers', cursive, sans-serif" font-size="13" fill="#0f380f" text-anchor="middle" letter-spacing="1" class="animate-pulse">START</text>
            </g>

            <!-- Screen (Hover: Active Teal) -->
            <g class="screen-hover">
              <rect x="46" y="40" width="104" height="72" fill="#2a9d8f" stroke="#1a1a2e" stroke-width="4" />
              
              <!-- Heart pixel art -->
              <path d="M92 50h4v6h-4zm12 0h4v6h-4zm-16 6h28v6H88zm0 6h28v6H88zm4 6h20v6H92zm4 6h12v6H96zm4 6h4v6h-4z" fill="#e63946" stroke="#1a1a2e" stroke-width="1" />
              
              <text x="98" y="102" font-family="'Bangers', cursive, sans-serif" font-size="13" fill="#ffffff" text-anchor="middle" letter-spacing="1">LET'S GO!</text>
            </g>

            <!-- D-pad -->
            <g class="dpad">
              <rect x="45" y="148" width="36" height="12" rx="2" ry="2" fill="#1a1a2e" />
              <rect x="57" y="136" width="12" height="36" rx="2" ry="2" fill="#1a1a2e" />
              <circle cx="63" cy="154" r="3" fill="#e2e8f0" />
            </g>

            <!-- A/B buttons -->
            <g>
              <!-- Labels -->
              <text x="122" y="180" font-family="monospace" font-weight="bold" font-size="8" fill="#1a1a2e">B</text>
              <text x="147" y="168" font-family="monospace" font-weight="bold" font-size="8" fill="#1a1a2e">A</text>
              
              <!-- Buttons -->
              <circle cx="122" cy="160" r="10" fill="#e63946" stroke="#1a1a2e" stroke-width="4" class="btn-b" />
              <circle cx="147" cy="148" r="10" fill="#ffd60a" stroke="#1a1a2e" stroke-width="4" class="btn-a" />
            </g>

            <!-- Start / Select buttons -->
            <g>
              <rect x="75" y="195" width="20" height="6" rx="2" ry="2" fill="#7a8a99" stroke="#1a1a2e" stroke-width="2" transform="rotate(-20 85 198)" />
              <rect x="105" y="195" width="20" height="6" rx="2" ry="2" fill="#7a8a99" stroke="#1a1a2e" stroke-width="2" transform="rotate(-20 115 198)" />
            </g>

            <!-- Speaker grilles -->
            <line x1="135" y1="205" x2="145" y2="195" stroke="#1a1a2e" stroke-width="4" stroke-linecap="round" />
            <line x1="142" y1="205" x2="152" y2="195" stroke="#1a1a2e" stroke-width="4" stroke-linecap="round" />
            <line x1="149" y1="205" x2="159" y2="195" stroke="#1a1a2e" stroke-width="4" stroke-linecap="round" />

            <!-- Pattern definition -->
            <defs>
              <pattern id="pixel-grid" width="4" height="4" patternUnits="userSpaceOnUse">
                <rect width="4" height="4" fill="none" />
                <path d="M 4 0 L 0 0 0 4" fill="none" stroke="#000" stroke-width="0.5" />
              </pattern>
            </defs>
          </svg>
        </div>

        <!-- Corner fold -->
        <div class="CS_corner-fold absolute bottom-0 right-0"></div>
      </div>

      <!-- POW badge -->
      <div class="absolute -bottom-2 -left-8 z-10">
        <svg width="90" height="90" viewBox="0 0 90 90">
          <polygon points="45,2 56,30 86,30 63,49 72,78 45,60 18,78 27,49 4,30 34,30"
            fill="#ffd60a" stroke="#1a1a2e" stroke-width="3"
            style="filter: drop-shadow(3px 3px 0px #1a1a2e)"/>
        </svg>
        <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-[52%]
                     font-bangers text-[22px] tracking-[2px] text-ink
                     -rotate-12 whitespace-nowrap select-none">
          WOW!
        </span>
      </div>

    </div>
  </div>

  <!-- Scroll hint -->
  <div class="CS_scroll-hint absolute bottom-7 left-1/2 -translate-x-1/2 z-20
              flex flex-col items-center gap-1.5
              font-bangers text-[13px] tracking-[3px] text-ink dark:text-paper">
    <span>SCROLL</span>
    <div class="CS_scroll-arrow"></div>
  </div>

  <style>
    /* Interactivity for Gameboy SVG */
    .btn-a, .btn-b, .dpad {
      transform-box: fill-box;
      transform-origin: center;
      transition: transform 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275), fill 0.15s ease;
    }
    .screen-hover {
      opacity: 0;
      transition: opacity 0.2s ease-in-out;
    }
    .screen-default {
      opacity: 1;
      transition: opacity 0.2s ease-in-out;
    }
    .console-body {
      transition: fill 0.3s ease;
    }

    /* When the avatar frame is hovered */
    .CS_avatar-frame:hover .btn-a {
      transform: scale(0.85) translate(1px, 2px);
      fill: #ffcdb2;
    }
    .CS_avatar-frame:hover .btn-b {
      transform: scale(0.85) translate(-1px, 2px);
      fill: #e07a5f;
    }
    .CS_avatar-frame:hover .dpad {
      transform: rotate(6deg) scale(0.95);
    }
    .CS_avatar-frame:hover .screen-default {
      opacity: 0;
    }
    .CS_avatar-frame:hover .screen-hover {
      opacity: 1;
    }
    .CS_avatar-frame:hover .console-body {
      fill: #fdf0d5;
    }
  </style>

</section>